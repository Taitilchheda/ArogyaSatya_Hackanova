flowchart TD
    %% =========================================
    %% ArogyaSatya: Research-Style Algorithmic Flow
    %% =========================================

    S0([Input Query qt: text, article URL, video, image])
    S1[Preprocessing and Normalization: language cleanup and metadata extraction]
    S2[Modality Router: detect modalities text, image, video, multi]
    S3[Video Transcription Node: Whisper to transcript]
    S4[Image Semantics Node: VLM descriptors and visual claims]
    S5[Safety Policy Node: medical safety and prompt abuse filter]
    D1{Safe to proceed?}
    S6[Atomic Claim Extraction: claim set C equals c1 to cn]
    D2{Claims extracted?}
    S7[Canonicalization and Deduplication: semantic mapping ci to kj]
    S8[Evidence Retrieval Stage 1: trusted web and local memory]
    S9[Evidence Retrieval Stage 2: PubMed augmentation]
    S10[Evidence Fusion: supporting, refuting, neutral aggregation]
    S11[Claim Verification Inference: status, confidence, rationale]
    S12[Calibration and Consistency Check: cross-claim coherence]
    S13[Report Synthesis: executive summary and per-claim trace]
    S14[(SQL Persistence: raw content, canonical claims, claim evidence)]
    S15[(Vector Persistence: claim embeddings and retrieval memory)]
    S16[Trend Mining: temporal clustering and narrative drift]
    S17([User-Facing Output: verdicts, evidence, explanation])

    E0([Safety Warning Output])
    E1([No-Claim Early Exit])

    S0 --> S1 --> S2
    S2 --> S3 --> S5
    S2 --> S4 --> S5
    S2 --> S5

    S5 --> D1
    D1 -- No --> E0
    D1 -- Yes --> S6

    S6 --> D2
    D2 -- No --> E1
    D2 -- Yes --> S7

    S7 --> S8 --> S9 --> S10 --> S11 --> S12 --> S13 --> S17
    S7 --> S15
    S11 --> S14
    S13 --> S14
    S14 --> S16
    S15 --> S16

    %% Feedback loops for continual improvement
    S16 -. trend priors .-> S8
    S12 -. inconsistency signal .-> S8
    S12 -. uncertainty signal .-> S9

    %% Styling
    classDef io fill:#eef2ff,stroke:#3730a3,color:#1e1b4b,stroke-width:1px;
    classDef process fill:#f8fafc,stroke:#334155,color:#0f172a,stroke-width:1px;
    classDef decision fill:#fff7ed,stroke:#c2410c,color:#7c2d12,stroke-width:1px;
    classDef store fill:#ecfdf5,stroke:#166534,color:#14532d,stroke-width:1px;
    classDef exit fill:#fef2f2,stroke:#b91c1c,color:#7f1d1d,stroke-width:1px;

    class S0,S17 io;
    class S1,S2,S3,S4,S5,S6,S7,S8,S9,S10,S11,S12,S13,S16 process;
    class D1,D2 decision;
    class S14,S15 store;
    class E0,E1 exit;
